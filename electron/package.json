{
  "name": "infra-panel-electron",
  "version": "1.3.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "build:win": "npm run build && electron-builder --win --config electron-builder.json",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.json",
    "start": "electron --no-sandbox dist/main.js",
    "dev": "tsc && electron --no-sandbox dist/main.js"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
