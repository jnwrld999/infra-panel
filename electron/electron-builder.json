{
  "appId": "com.infrapanel.app",
  "productName": "InfraPanel",
  "directories": {
    "output": "InfraPanel",
    "app": "."
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "target": [{ "target": "portable", "arch": ["x64"] }]
  },
  "portable": {
    "artifactName": "InfraPanel-windows.exe"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "category": "Utility"
  },
  "appImage": {
    "artifactName": "InfraPanel-${version}.AppImage"
  }
}
